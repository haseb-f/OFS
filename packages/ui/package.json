{
  "name": "@ofs/ui",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens.css": "./src/tokens/tokens.css",
    "./base.css": "./src/styles/base.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo storybook-static"
  },
  "dependencies": {
    "@ofs/config": "workspace:*",
    "@ofs/types": "workspace:*",
    "@ofs/utils": "workspace:*",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.1",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
