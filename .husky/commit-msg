#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Enforce Conventional Commits format
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

PATTERN="^(feat|fix|chore|docs|test|refactor|ci|perf|style|revert)(\(.+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "✗ Commit message rejected."
  echo ""
  echo "  Required format: <type>(<scope>): <description>"
  echo "  Allowed types:   feat, fix, chore, docs, test, refactor, ci, perf, style, revert"
  echo ""
  echo "  Examples:"
  echo "    feat(api): add tenant guard with subdomain resolution"
  echo "    fix(web): correct rtl layout in dashboard header"
  echo "    chore: update pnpm lockfile"
  echo ""
  exit 1
fi
