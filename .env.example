# ============================================================
# OFS — Root Environment Variable Contract
# Copy to .env.local and fill in real values for local dev.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# Node environment
NODE_ENV=development

# ── Database ────────────────────────────────────────────────
# PgBouncer transaction-mode connection (used by Prisma at runtime)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?pgbouncer=true&connection_limit=1

# Read replica (falls back to DATABASE_URL if not set — warning logged)
DATABASE_READ_URL=

# Direct connection bypassing PgBouncer (used by prisma migrate only)
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<from: supabase status>
SUPABASE_SERVICE_ROLE_KEY=<from: supabase status>

# JWT secret for local verification (no Supabase API call per request)
API_JWT_SECRET=<from: supabase status → JWT secret>

# ── API (apps/api) ──────────────────────────────────────────
PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3007

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Frontend (apps/web) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from: supabase status>

# ── Turborepo Remote Cache ───────────────────────────────────
TURBO_TOKEN=<from: vercel dashboard>
TURBO_TEAM=<your-vercel-team-slug>
