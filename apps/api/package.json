    "@ofs/api-contracts": "workspace:*",
    "@ofs/audit": "workspace:*",
    "@ofs/config": "workspace:*",
    "@ofs/database": "workspace:*",
    "@ofs/logger": "workspace:*",
    "@ofs/types": "workspace:*",
    "@ofs/utils": "workspace:*",
    "@ofs/validation": "workspace:*",
    "@prisma/client": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
