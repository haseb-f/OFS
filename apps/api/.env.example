# apps/api — Backend Environment Variables
# These variables are only available server-side.
# Never expose SERVICE_ROLE_KEY or JWT secrets to the frontend.

NODE_ENV=development
PORT=3001

# Database (PgBouncer transaction mode)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?pgbouncer=true&connection_limit=1
DATABASE_READ_URL=
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=<from: supabase status>
API_JWT_SECRET=<from: supabase status → JWT secret>

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3007

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
